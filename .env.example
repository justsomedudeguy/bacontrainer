# App runtime
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
APP_MODE=live
USAGE_LOG_DIRECTORY=logs
DEFAULT_PROVIDER=gemini
COURTLISTENER_BASE_URL=https://www.courtlistener.com
COURTLISTENER_API_TOKEN=

# OpenAI-compatible provider
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=openrouter/free

# Ollama provider
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Gemini provider
# Leave GEMINI_API_KEY blank to use Vertex AI as the server default.
# A browser-entered Gemini API key still overrides Vertex for that browser.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_VERTEX_PROJECT=
GEMINI_VERTEX_LOCATION=us-central1
